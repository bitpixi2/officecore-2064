{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bitpixi2/officecore-2064/Game-Test-Bitpixi/data/officecore-kit.schema.json",
  "title": "Officecore 2064 Game Test - Bitpixi Kit",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "characters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/character"
      }
    },
    "encounters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/encounter"
      }
    },
    "crewState": {
      "$ref": "#/$defs/crewState"
    }
  },
  "required": [
    "characters",
    "encounters"
  ],
  "$defs": {
    "statBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spark": {
          "type": "integer",
          "minimum": -1,
          "maximum": 3
        },
        "signal": {
          "type": "integer",
          "minimum": -1,
          "maximum": 3
        },
        "grit": {
          "type": "integer",
          "minimum": -1,
          "maximum": 3
        },
        "charm": {
          "type": "integer",
          "minimum": -1,
          "maximum": 3
        },
        "drift": {
          "type": "integer",
          "minimum": -1,
          "maximum": 3
        }
      },
      "required": [
        "spark",
        "signal",
        "grit",
        "charm",
        "drift"
      ]
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "handle": {
          "type": "string",
          "minLength": 1
        },
        "pronouns": {
          "type": "string"
        },
        "presentation": {
          "type": "string"
        },
        "officeTell": {
          "type": "string"
        },
        "speciesKind": {
          "type": "string",
          "enum": [
            "Human Local",
            "Roo-Kin",
            "Brush-Tail Night Clerk",
            "Magpie Protocol",
            "Civic Daemon",
            "Myco-Union Rep",
            "Receipt Revenant"
          ]
        },
        "vanName": {
          "type": "string",
          "minLength": 1
        },
        "camperShell": {
          "type": "string",
          "minLength": 1
        },
        "dedicatedModule": {
          "type": "string",
          "minLength": 1
        },
        "mobileMode": {
          "type": "string",
          "minLength": 1
        },
        "embarrassingDetail": {
          "type": "string"
        },
        "specialty": {
          "type": "string",
          "enum": [
            "Signal Runner",
            "Patch Ratchet",
            "Vibe Broker",
            "Bushwire Scout",
            "Compliance Bard",
            "Data-Centre Whisperer",
            "Rooby Rancher"
          ]
        },
        "stats": {
          "$ref": "#/$defs/statBlock"
        },
        "bonds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 0
        },
        "secret": {
          "type": "string"
        },
        "fault": {
          "type": "string"
        },
        "upgradeWish": {
          "type": "string"
        },
        "startingKit": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provenance": {
          "type": "string",
          "enum": [
            "human-written",
            "agent-assisted",
            "agent-generated-human-edited",
            "other"
          ]
        }
      },
      "required": [
        "id",
        "handle",
        "speciesKind",
        "vanName",
        "camperShell",
        "dedicatedModule",
        "mobileMode",
        "specialty",
        "stats",
        "bonds",
        "secret",
        "fault",
        "upgradeWish"
      ]
    },
    "crewState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "charge": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "trust": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "smoke": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "heat": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "signal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      },
      "required": [
        "charge",
        "trust",
        "smoke",
        "heat",
        "signal"
      ]
    },
    "encounter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "premise": {
          "type": "string",
          "minLength": 1
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "factions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "clocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "challenges": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "rewards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "toneTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "randomTables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/randomTable"
          }
        }
      },
      "required": [
        "id",
        "title",
        "premise",
        "locations",
        "factions",
        "challenges"
      ]
    },
    "randomTable": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "die": {
          "type": "string",
          "pattern": "^1d[0-9]+$"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": [
        "name",
        "die",
        "entries"
      ]
    }
  }
}
